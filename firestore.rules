rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function sortedId(a, b) {
      return a < b ? a + '_' + b : b + '_' + a;
    }

    function areConnected(uid1, uid2) {
      return exists(/databases/$(database)/documents/connections/$(sortedId(uid1, uid2)));
    }

    // ─── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isOwner(uid);

      allow update: if isOwner(uid)
        && !request.resource.data.isBanned
        && !(request.resource.data.isVerified == true
             && resource.data.isVerified == false);

      allow delete: if isOwner(uid);

      // ─── Coin Transactions ──────────────────────────────────────────────────
      match /coinTransactions/{txId} {
        allow read:             if isOwner(uid);
        allow create:           if isOwner(uid)
          && request.resource.data.uid == uid
          && request.resource.data.createdAt is number
          && request.resource.data.amount is number;
        allow update, delete:   if false;
      }

      // ─── Memories ───────────────────────────────────────────────────────────
      match /memories/{memoryId} {
        allow read: if isOwner(uid)
          || (isSignedIn()
              && resource.data.isPrivate == false
              && areConnected(request.auth.uid, uid));
        allow write: if isOwner(uid);
      }
    }

    // ─── Connection Requests ───────────────────────────────────────────────────

    match /connectionRequests/{requestId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);

      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.status == 'pending'
        && request.resource.data.note is string
        && request.resource.data.note.size() > 0
        && request.resource.data.note.size() <= 300;

      allow update: if isSignedIn()
        && ((request.auth.uid == resource.data.toUid
              && request.resource.data.status in ['accepted', 'declined'])
            || (request.auth.uid == resource.data.fromUid
              && request.resource.data.status == 'withdrawn'));

      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.fromUid;
    }

    // ─── Connections ──────────────────────────────────────────────────────────

    match /connections/{connectionId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.users;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users.size() == 2;

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.users;

      allow delete: if false;

      // ─── Messages ───────────────────────────────────────────────────────────
      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in
             get(/databases/$(database)/documents/connections/$(connectionId)).data.users;

        allow create: if isSignedIn()
          && request.auth.uid in
             get(/databases/$(database)/documents/connections/$(connectionId)).data.users
          && request.auth.uid == request.resource.data.senderId
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;

        allow update, delete: if false;
      }
    }

    // ─── Statuses ─────────────────────────────────────────────────────────────

    match /statuses/{uid} {
      allow read: if isSignedIn()
        && (resource.data.audience == 'everyone'
            || areConnected(request.auth.uid, uid)
            || request.auth.uid == uid);

      // expiresAt is validated in app code — server-clock comparison is unreliable
      // across client/server time skew. Only enforce ownership.
      allow write: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.expiresAt is number;
    }

    // ─── Events ───────────────────────────────────────────────────────────────

    match /events/{eventId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 3
        && request.resource.data.date > request.time.toMillis();

      allow update: if isSignedIn()
        && (resource.data.hostId == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['attendees']));

      allow delete: if isSignedIn()
        && resource.data.hostId == request.auth.uid;
    }

    // ─── Posts ────────────────────────────────────────────────────────────────

    match /posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.caption is string
        && request.resource.data.caption.size() <= 1000;

      // Any signed-in user can update social fields (likes, saves, comment count).
      // Only the post owner can change anything else.
      allow update: if isSignedIn()
        && (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['likes', 'savedBy', 'commentCount', 'comments', 'shareCount'])
            || resource.data.userId == request.auth.uid);

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      // ─── Comments subcollection ────────────────────────────────────────────
      match /comments/{commentId} {
        // Any signed-in user can read comments on any post
        allow read: if isSignedIn();

        // Any signed-in user can create a comment (must be their own)
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300;

        // Only comment author can delete their own comment
        allow delete: if isSignedIn()
          && resource.data.userId == request.auth.uid;

        allow update: if false;
      }
    }

    // ─── Game Rooms ───────────────────────────────────────────────────────────

    match /gameRooms/{roomId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'waiting';

      // Any signed-in user can update (join/ready/state sync). Tightened later
      // once server-side game logic moves to Cloud Functions / Node backend.
      allow update: if isSignedIn();

      allow delete: if isSignedIn()
        && resource.data.hostUid == request.auth.uid;

      // ─── In-game chat subcollection ─────────────────────────────────────────
      // Any authenticated participant can read and write chat messages.
      match /chat/{msgId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300
          && request.resource.data.createdAt is number;
        allow update, delete: if false;
      }
    }

    // ─── Game Invites ─────────────────────────────────────────────────────────

    match /gameInvites/{inviteId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);

      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.expiresAt > request.time.toMillis();

      allow update: if isSignedIn()
        && ((request.auth.uid == resource.data.toUid
              && request.resource.data.status in ['accepted', 'declined'])
            || (request.auth.uid == resource.data.fromUid
              && request.resource.data.status == 'expired'));

      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.fromUid;
    }

    // ─── User Notifications ───────────────────────────────────────────────────
    // Cloud Functions write via Admin SDK (bypasses rules).
    // Client reads/updates only their own notifications.

    match /userNotifications/{notifId} {
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if false;
    }

    // ─── Event Invites ────────────────────────────────────────────────────────

    match /eventInvites/{inviteId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);

      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isSignedIn()
        && request.auth.uid == resource.data.toUid
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      allow delete: if false;
    }

    // ─── User Sessions ────────────────────────────────────────────────────────
    // Lightweight online-presence tracking (city, lastActive, online flag).

    match /userSessions/{uid} {
      // Any signed-in user can read sessions (powers "X people near you" count)
      allow read: if isSignedIn();

      // Only the session owner can create/update their own session doc
      allow create, update: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.lastActive is number
        && request.resource.data.online is bool;

      allow delete: if false;
    }

    // ─── Reports ─────────────────────────────────────────────────────────────
    // Write-only: any signed-in user can file a report; no client reads.

    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ─── Admin Notifications ──────────────────────────────────────────────────
    // App can queue (create); Cloud Functions process; no client read.

    match /adminNotifications/{notifId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // ─── Admin Config ─────────────────────────────────────────────────────────
    // Server-only (Admin SDK). No client access.

    match /adminConfig/{docId} {
      allow read, write: if false;
    }

    // ─── Top-level Coin Transactions ──────────────────────────────────────────
    // Cloud Functions write via Admin SDK. Users can read their own.

    match /coinTransactions/{txId} {
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ─── Admins ───────────────────────────────────────────────────────────────
    // Written by the admin web app during signup. Owner can read their own doc.

    match /admins/{uid} {
      allow read:           if isSignedIn() && request.auth.uid == uid;
      allow create:         if isSignedIn() && request.auth.uid == uid;
      allow update, delete: if false;
    }

    // ─── Feedback ─────────────────────────────────────────────────────────────
    // Signed-in users can submit; no client reads (admin-only via Admin SDK).
    match /feedback/{docId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow read, update, delete: if false;
    }

    // ─── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
